<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- Universal Top Bar -->
    <LinearLayout
        android:id="@+id/settingsTopBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:background="@color/surface"
        android:elevation="4dp">

        <ImageButton
            android:id="@+id/btnBackSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_arrow_back"
            android:padding="8dp"
            android:contentDescription="Back" />

        <TextView
            android:id="@+id/tvSettingsTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Settings"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/on_surface" />

        <!-- + icon for scripts tab -->
        <ImageButton
            android:id="@+id/btnSettingsAdd"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_add"
            android:padding="8dp"
            android:visibility="gone"
            android:contentDescription="@string/add_script" />

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/outline"
        android:alpha="0.3" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ══════════════════════════════════════════════════════ -->
            <!-- GENERAL SETTINGS CONTAINER                            -->
            <!-- ══════════════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/generalContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- ── Section: Browser ───────────────────────── -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="6dp"
                    android:text="BROWSER"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12"
                    android:textColor="@color/on_surface_variant" />

                <!-- Homepage URL with dropdown -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Default Homepage"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:layout_marginBottom="10dp"
                        android:text="Select or type the URL loaded on new tab"
                        android:textSize="13sp"
                        android:textColor="@color/on_surface_variant" />

                    <!-- Spinner / dropdown for preset URLs -->
                    <Spinner
                        android:id="@+id/spinnerHomepage"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_spinner"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:textColor="@color/on_surface" />

                    <!-- Custom URL input (shown when "Custom…" is selected) -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilCustomHomepage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:visibility="gone"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense"
                        app:boxCornerRadiusTopStart="8dp"
                        app:boxCornerRadiusTopEnd="8dp"
                        app:boxCornerRadiusBottomStart="8dp"
                        app:boxCornerRadiusBottomEnd="8dp"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etHomepageUrl"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textUri|textNoSuggestions"
                            android:imeOptions="actionDone"
                            android:singleLine="true"
                            android:hint="https://www.google.com"
                            android:textSize="14sp"
                            android:textColor="@color/on_surface" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:background="@color/outline"
                    android:alpha="0.4" />

                <!-- ── Section: Appearance ─────────────────────── -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="6dp"
                    android:text="APPEARANCE"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12"
                    android:textColor="@color/on_surface_variant" />

                <!-- Dark / Light theme toggle -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:background="?attr/selectableItemBackground">

                    <LinearLayout
                        android:id="@+id/themeTextBlock"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_toStartOf="@+id/switchDarkMode"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:paddingEnd="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Dark Mode"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Switch between light and dark theme"
                            android:textSize="13sp"
                            android:textColor="@color/on_surface_variant" />
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchDarkMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:background="@color/outline"
                    android:alpha="0.4" />

                <!-- ── Section: Privacy ───────────────────────── -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="6dp"
                    android:text="PRIVACY"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12"
                    android:textColor="@color/on_surface_variant" />

                <!-- Clear data on exit toggle -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:background="?attr/selectableItemBackground">

                    <LinearLayout
                        android:id="@+id/clearExitTextBlock"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_toStartOf="@+id/switchClearOnExit"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:paddingEnd="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Clear data on exit"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Clears cache, cookies and history when app is closed"
                            android:textSize="13sp"
                            android:textColor="@color/on_surface_variant" />
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchClearOnExit"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:background="@color/outline"
                    android:alpha="0.4" />

                <!-- Clear data now row -->
                <LinearLayout
                    android:id="@+id/btnClearDataNow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_delete"
                        android:layout_marginEnd="16dp"
                        android:tint="@color/on_surface"
                        android:contentDescription="Clear" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Clear browsing data now"
                        android:textSize="15sp"
                        android:textColor="@color/on_surface" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_arrow_forward"
                        android:tint="@color/on_surface_variant"
                        android:contentDescription="" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:background="@color/outline"
                    android:alpha="0.4" />

                <!-- ── Section: Content ───────────────────────── -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="6dp"
                    android:text="CONTENT"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12"
                    android:textColor="@color/on_surface_variant" />

                <!-- Ad Blocking row -->
                <LinearLayout
                    android:id="@+id/btnGoAdBlocking"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_security"
                        android:layout_marginEnd="16dp"
                        android:tint="@color/on_surface"
                        android:contentDescription="Ad Blocking" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ad Blocking"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Block ads and trackers"
                            android:textSize="13sp"
                            android:textColor="@color/on_surface_variant" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_arrow_forward"
                        android:tint="@color/on_surface_variant"
                        android:contentDescription="" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:background="@color/outline"
                    android:alpha="0.4" />

                <!-- User Scripts row -->
                <LinearLayout
                    android:id="@+id/btnGoUserScripts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_script"
                        android:layout_marginEnd="16dp"
                        android:tint="@color/on_surface"
                        android:contentDescription="User Scripts" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="User Scripts"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/on_surface" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Manage and run custom scripts on pages"
                            android:textSize="13sp"
                            android:textColor="@color/on_surface_variant" />
                    </LinearLayout>

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_arrow_forward"
                        android:tint="@color/on_surface_variant"
                        android:contentDescription="" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="24dp" />

            </LinearLayout>

            <!-- ══════════════════════════════════════════════════════ -->
            <!-- AD BLOCKING CONTAINER                                 -->
            <!-- ══════════════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/adBlockingContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="6dp"
                    android:text="FILTERS"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12"
                    android:textColor="@color/on_surface_variant" />

                <!-- Ad blocking main switch -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:background="?attr/selectableItemBackground">
                    <TextView
                        android:id="@+id/tvAdBlockTitle1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ad blocking"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:layout_toStartOf="@+id/switchAdBlocking"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:paddingEnd="16dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/tvAdBlockTitle1"
                        android:layout_marginTop="3dp"
                        android:text="Block ads and trackers while browsing"
                        android:textSize="13sp"
                        android:textColor="@color/on_surface_variant"
                        android:layout_toStartOf="@+id/switchAdBlocking"
                        android:layout_alignParentStart="true"
                        android:paddingEnd="16dp" />
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchAdBlocking"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:checked="true" />
                </RelativeLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
                    android:background="@color/outline" android:alpha="0.3" />

                <!-- Built-in filters switch -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:background="?attr/selectableItemBackground">
                    <TextView
                        android:id="@+id/tvAdBlockTitle2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Enable built-in filters"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:layout_toStartOf="@+id/switchFilters"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:paddingEnd="16dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/tvAdBlockTitle2"
                        android:layout_marginTop="3dp"
                        android:text="Block common ads using built-in filter lists"
                        android:textSize="13sp"
                        android:textColor="@color/on_surface_variant"
                        android:layout_toStartOf="@+id/switchFilters"
                        android:layout_alignParentStart="true"
                        android:paddingEnd="16dp" />
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchFilters"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:checked="true" />
                </RelativeLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
                    android:background="@color/outline" android:alpha="0.3" />

                <!-- Expand content switch -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:background="?attr/selectableItemBackground">
                    <TextView
                        android:id="@+id/tvAdBlockTitle5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Expand webpage content"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:layout_toStartOf="@+id/switchExpand"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:paddingEnd="16dp" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/tvAdBlockTitle5"
                        android:layout_marginTop="3dp"
                        android:text="Expand collapsed content automatically on load"
                        android:textSize="13sp"
                        android:textColor="@color/on_surface_variant"
                        android:layout_toStartOf="@+id/switchExpand"
                        android:layout_alignParentStart="true"
                        android:paddingEnd="16dp" />
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchExpand"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:checked="true" />
                </RelativeLayout>

            </LinearLayout>

            <!-- ══════════════════════════════════════════════════════ -->
            <!-- SCRIPTS CONTAINER                                     -->
            <!-- ══════════════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/scriptsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="6dp"
                    android:text="SETTINGS"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12"
                    android:textColor="@color/on_surface_variant" />

                <!-- Master enable switch -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:background="?attr/selectableItemBackground">

                    <TextView
                        android:id="@+id/tvScriptsTitle1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Enable user scripts"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:layout_centerVertical="true"
                        android:layout_toStartOf="@+id/switchEnableScripts"
                        android:layout_alignParentStart="true"
                        android:paddingEnd="16dp" />

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchEnableScripts"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:checked="true" />
                </RelativeLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
                    android:background="@color/outline" android:alpha="0.3" />

                <!-- Scripts section label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="6dp"
                    android:text="INSTALLED SCRIPTS"
                    android:textSize="11sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.12"
                    android:textColor="@color/on_surface_variant" />

                <!-- Empty state message -->
                <TextView
                    android:id="@+id/tvNoScripts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="24dp"
                    android:gravity="center"
                    android:text="@string/no_scripts"
                    android:textSize="14sp"
                    android:textColor="@color/on_surface_variant"
                    android:visibility="visible" />

                <!-- Dynamic list of user scripts goes here -->
                <LinearLayout
                    android:id="@+id/scriptsListContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>

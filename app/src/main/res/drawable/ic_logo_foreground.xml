<?xml version="1.0" encoding="utf-8"?>
<!--
    This is a placeholder foreground for the launcher icon.
    To use the actual logo.svg:
      1. In Android Studio → right-click res/drawable → New → Vector Asset
      2. Choose "Local file (SVG, PSD)" and select lgo.svg from the project root
      3. Name it ic_logo_foreground and click Finish
    The adaptive icon (mipmap-anydpi-v26/ic_launcher.xml) already references this name.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Browser globe / tool icon representation -->
    <!-- Outer circle -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,18 A36,36 0 1,1 53.999,18 Z" />

    <!-- Globe meridian lines -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#1A73E8"
        android:strokeWidth="2.5"
        android:pathData="M54,18 A36,36 0 1,1 53.999,18 Z" />
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#1A73E8"
        android:strokeWidth="2"
        android:pathData="M54,18 C44,28 44,62 54,72 C64,62 64,28 54,18 Z" />
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#1A73E8"
        android:strokeWidth="1.5"
        android:pathData="M18,54 L90,54" />
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#1A73E8"
        android:strokeWidth="1.5"
        android:pathData="M21,38 L87,38 M21,70 L87,70" />

    <!-- Wrench / tool overlay at bottom-right -->
    <path
        android:fillColor="#1A73E8"
        android:pathData="M73,67 L79,61 A8,8 0 0,0 69,51 L65,55 L69,59 L67,61 L71,65 Z" />

</vector>
